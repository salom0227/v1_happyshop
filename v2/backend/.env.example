# Copy to .env and set values. Used by python-dotenv in settings.py.

# Django
DJANGO_SECRET_KEY=your-secret-key
DJANGO_DEBUG=True
# Tarmoq orqali kirish: localhost,127.0.0.1,192.168.0.134 (o'z IP ingiz)
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Redis (ixtiyoriy — bo'lmasa xotira cache ishlatiladi)
# REDIS_URL=redis://127.0.0.1:6379/1

# PostgreSQL
POSTGRES_DB=happy_shop
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Sayt to'liq URL (ixtiyoriy; masalan production: https://yoursite.com)
SITE_URL=http://127.0.0.1:8000

# Telegram — buyurtma cheki shu kanal/guruhga yuboriladi
# 1) @BotFather da bot yarating, token oling
# 2) Kanal/guruh bo'lsa: botni admin qiling; shaxsiy chat bo'lsa: botga /start yuboring
# 3) Chat ID: kanal/guruh (masalan -100xxxxxxxxxx) yoki shaxsiy (masalan 5269410357)
TELEGRAM_BOT_TOKEN=123456:ABC...
TELEGRAM_CHAT_ID=-1001234567890
